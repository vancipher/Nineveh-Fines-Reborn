{
  "name": "fines-system-reborn",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:https": "next dev --experimental-https -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node -e \"if(process.env.VERCEL){process.exit(0)}; try{require('better-sqlite3')}catch(e){process.exit(0)}\" || npm rebuild better-sqlite3",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:update-admin": "tsx src/lib/db/update-default-admin.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "setup:superadmin": "tsx scripts/ensure-superadmin.ts",
    "reset:superadmin": "node scripts/reset-superadmin-password.mjs",
    "password:superadmin": "node scripts/generate-superadmin-password.mjs",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "verify:local": "node scripts/verify-release.mjs",
    "verify:prod": "node scripts/verify-production.mjs"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "docx": "^9.7.1",
    "drizzle-orm": "^0.39.3",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "html-to-image": "^1.11.13",
    "jose": "^5.10.0",
    "lucide-react": "^1.17.0",
    "next": "^15.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "drizzle-kit": "^0.30.5",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.5.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
