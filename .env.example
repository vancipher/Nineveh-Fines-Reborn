# Auth (required)
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Database
# Local development (SQLite file):
DATABASE_URL=file:./data/local.db

# Production on Turso (recommended free tier):
# DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# Seeded admin account (first run only — change before production)
ADMIN_EMAIL=admin@nineveh-traffic.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Voice default language (ar-SA recommended for Edge; ar-IQ | en-US)
DEFAULT_VOICE_LANGUAGE=ar-SA

# Optional: server-side speech (works when browser Web Speech fails — free key at https://console.groq.com)
# GROQ_API_KEY=gsk_...

# Optional: Gemini API (graphify semantic extraction — https://aistudio.google.com/apikey)
# GEMINI_API_KEY=

# Optional: path to official Excel template (defaults to /Assets/*.xlsx)
# TEMPLATE_XLSX=./Assets/موقف المخالفات مع المبالغ.xlsx

# App URL (used for Google OAuth redirect; on Vercel this is set automatically if omitted)
APP_URL=https://localhost:3000
# VERCEL sets VERCEL_URL automatically — APP_URL overrides for OAuth

# Google Drive backup (create OAuth credentials at https://console.cloud.google.com)
# Enable Google Drive API, create OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: https://localhost:3000/api/admin/backup/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://localhost:3000/api/admin/backup/google/callback
